# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=wayback
DB_PASSWORD=
DB_NAME=wayback

# Server Configuration
SERVER_HOST=127.0.0.1
SERVER_PORT=8080

# Compression Settings
# Note: Request decompression is always enabled (supports both compressed and uncompressed requests)
# This setting only controls response compression
#
# For local deployment (localhost): Keep disabled (default)
# For remote deployment: Enable compression on both client and server
ENABLE_COMPRESSION=false
# Compression level: 1 (fastest) to 9 (best compression), -1 (default/balanced)
COMPRESSION_LEVEL=-1

# CORS Configuration - Comma-separated list of allowed origins
# For local development:
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,null
# For remote deployment, add your domain:
# ALLOWED_ORIGINS=https://your-domain.com,http://localhost:8080,null

# Authentication (REQUIRED for remote deployment)
AUTH_PASSWORD=

# Storage Configuration
DATA_DIR=./data
LOG_DIR=./data/logs
