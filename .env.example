# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=wayback
DB_PASSWORD=
DB_NAME=wayback

# Server Configuration
SERVER_HOST=127.0.0.1
SERVER_PORT=8080

# Compression Settings
# Response compression is always enabled and auto-negotiated via Accept-Encoding header
# (clients that support gzip get compressed responses, others get uncompressed)
# Request decompression is always enabled (supports both compressed and uncompressed uploads)
#
# Client-side compression (browser upload): Configure in browser/src/config.ts
# - For local deployment: Keep ENABLE_COMPRESSION: false (default)
# - For remote deployment: Set ENABLE_COMPRESSION: true
#
# Compression level: 1 (fastest) to 9 (best compression), -1 (default/balanced)
COMPRESSION_LEVEL=-1

# CORS Configuration - Comma-separated list of allowed origins
# For local development:
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,null
# For remote deployment, add your domain:
# ALLOWED_ORIGINS=https://your-domain.com,http://localhost:8080,null

# Authentication (REQUIRED for remote deployment)
AUTH_PASSWORD=

# Storage Configuration
DATA_DIR=./data
LOG_DIR=./data/logs

# Resource Processing Configuration
# All values default to auto-detection based on system resources (set 0 or omit to auto-detect)
#
# Concurrent download workers (default: CPU cores × 4, min 2, I/O bound task)
# RESOURCE_WORKERS=4
#
# Resource ID cache size in MB (default: 10% of total memory)
# RESOURCE_CACHE_MB=256
#
# Single resource download timeout in seconds (default: 30)
# RESOURCE_DOWNLOAD_TIMEOUT=30
#
# Large file streaming threshold in KB (default: 2048 = 2MB)
# Files larger than this are streamed to disk during download instead of being held in memory
# RESOURCE_STREAM_THRESHOLD_KB=2048
